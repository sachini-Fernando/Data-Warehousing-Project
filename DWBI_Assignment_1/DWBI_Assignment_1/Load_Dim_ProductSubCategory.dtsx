        <pipeline
          version="1">
          <components>
            <component
              refId="Package\DFT_Load_ProductSubCategory\Extract Product SubCategory Staging"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="Extract Product SubCategory Staging"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">-- For Product SubCategory - Extract distinct subcategories with category mapping
WITH CategoryCTE AS (
    SELECT DISTINCT
        ROW_NUMBER() OVER (ORDER BY conv_ProductCategory) AS ProductCategoryID,
        conv_ProductCategory AS ProductCategoryName
    FROM Products_Staging
    WHERE conv_ProductCategory IS NOT NULL 
      AND conv_ProductCategory != ''
      AND conv_ProductCategory != 'NULL'
      AND Processed = 0
)
SELECT DISTINCT
    ROW_NUMBER() OVER (ORDER BY cat.ProductCategoryID, ps.conv_SubCategory) AS ProductSubCategoryID,
    cat.ProductCategoryID,
    ps.conv_SubCategory AS ProductSubCategoryName,
    GETDATE() AS ModifiedDate
FROM Products_Staging ps
INNER JOIN CategoryCTE cat ON ps.conv_ProductCategory = cat.ProductCategoryName
WHERE ps.conv_SubCategory IS NOT NULL 
  AND ps.conv_SubCategory != ''
  AND ps.conv_SubCategory != 'NULL'
  AND ps.Processed = 0
ORDER BY cat.ProductCategoryID, ps.conv_SubCategory;</property>
                <property
                  dataType="System.String"
                  description="The variable that contains the SQL command to be executed."
                  name="SqlCommandVariable"></property>
                <property
