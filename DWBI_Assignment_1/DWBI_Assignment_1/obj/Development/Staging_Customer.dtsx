                    <arrayElement
                      dataType="System.String"><![CDATA[using System;
using System.Data;
using Microsoft.SqlServer.Dts.Pipeline.Wrapper;
using Microsoft.SqlServer.Dts.Runtime.Wrapper;
using System.Security.Cryptography;
using System.Text;

[Microsoft.SqlServer.Dts.Pipeline.SSISScriptComponentEntryPointAttribute]
public class ScriptMain : UserComponent
{
    public override void Input0_ProcessInputRow(Input0Buffer Row)
    {
        try
        {
            // Build concatenated string directly
            string concatenated = Row.CustomerNameCleaned + "|" +
                                  Row.CustomerGenderCleaned + "|" +
                                  Row.CustomerAgeValidated.ToString() + "|" +
                                  Row.CustomerSegmentCleaned + "|" +
                                  Row.RegionCleaned + "|" +
                                  Row.LoyaltyTierCleaned + "|" +
                                  Row.CustomerTenureValidated.ToString();

            // Generate SHA256 hash
            using (SHA256 sha256 = SHA256.Create())
            {
                byte[] hashBytes = sha256.ComputeHash(Encoding.UTF8.GetBytes(concatenated));
                Row.HashValue = BitConverter.ToString(hashBytes).Replace("-", "").ToLower();
            }
        }
        catch
        {
            Row.HashValue_IsNull = true;
        }
    }
}]]></arrayElement>
