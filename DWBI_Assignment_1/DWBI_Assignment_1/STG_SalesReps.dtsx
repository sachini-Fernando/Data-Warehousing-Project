            }
        }
        else
        {
            // Row.SalesRepIDInt = 0;
        }

        // ============================================
        // 2. Clean SalesRep Name
        // ============================================
        if (!Row.SalesRepName_IsNull && !string.IsNullOrWhiteSpace(Row.SalesRepName))
        {
            Row.SalesRepNameCleaned = Row.SalesRepName.Trim();
        }
        else
        {
            Row.SalesRepNameCleaned = "Unknown";
        }

        // ============================================
        // 3. Clean Region
        // ============================================
        if (!Row.Region_IsNull && !string.IsNullOrWhiteSpace(Row.Region))
        {
            Row.RegionCleaned = Row.Region.Trim().ToUpper();
        }
        else
        {
            Row.RegionCleaned = "UNKNOWN";
        }

        // ============================================
        // 4. Clean Team
        // ============================================
        if (!Row.Team_IsNull && !string.IsNullOrWhiteSpace(Row.Team))
        {
            Row.TeamCleaned = Row.Team.Trim().ToUpper();
        }
        else
        {
            Row.TeamCleaned = "UNKNOWN";
        }

        // ============================================
        // 5. Clean Title
        // ============================================
        if (!Row.Title_IsNull && !string.IsNullOrWhiteSpace(Row.Title))
        {
            Row.TitleCleaned = Row.Title.Trim().ToUpper();
        }
        else
        {
            Row.TitleCleaned = "UNKNOWN";
        }

        // ============================================
        // 6. Safe Conversion for HireDate (as DT_DBDATE)
        // ============================================
        DateTime hireDate = new DateTime(1900, 1, 1);
        if (!Row.HireDate_IsNull && !string.IsNullOrWhiteSpace(Row.HireDate))
        {
            // Try to parse the date
            if (DateTime.TryParse(Row.HireDate.Trim(), out hireDate))
            {
                // Validate date (cannot be future)
                if (hireDate > DateTime.Now)
                {
                    hireDate = DateTime.Now;
                }
                // Store as DT_DBDATE (date only)
                Row.HireDateDate = hireDate;
            }
            else
            {
                Row.HireDateDate = new DateTime(1900, 1, 1);
            }
        }
        else
        {
            Row.HireDateDate = new DateTime(1900, 1, 1);
        }
    }
