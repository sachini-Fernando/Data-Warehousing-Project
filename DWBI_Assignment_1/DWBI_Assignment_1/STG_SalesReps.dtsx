        if (!Row.SalesRepID_IsNull && !string.IsNullOrWhiteSpace(Row.SalesRepID))
        {
            // Remove all non-numeric characters
            string cleanedId = Regex.Replace(Row.SalesRepID.Trim(), @"[^\d]", "");
            if (!string.IsNullOrEmpty(cleanedId) && int.TryParse(cleanedId, out salesRepId))
            {
