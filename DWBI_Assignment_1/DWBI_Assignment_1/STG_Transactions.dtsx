                    <arrayElement
                      dataType="System.String"><![CDATA[using System;
using System.Data;
using Microsoft.SqlServer.Dts.Pipeline.Wrapper;
using Microsoft.SqlServer.Dts.Runtime.Wrapper;

[Microsoft.SqlServer.Dts.Pipeline.SSISScriptComponentEntryPointAttribute]
public class ScriptMain : UserComponent
{
    private int rowCount = 0;

    public override void Input0_ProcessInputRow(Input0Buffer Row)
    {
        rowCount++;

        // Debug: Write first 5 rows to output window
        if (rowCount <= 5)
        {
            System.Diagnostics.Debug.WriteLine($"=== Row {rowCount} ===");
            System.Diagnostics.Debug.WriteLine($"TransactionID: {Row.TransactionID}");
            System.Diagnostics.Debug.WriteLine($"TransactionDate: {Row.TransactionDate}");
            System.Diagnostics.Debug.WriteLine($"ProductID: {Row.ProductID}");
            System.Diagnostics.Debug.WriteLine($"CustomerID: {Row.CustomerID}");
            System.Diagnostics.Debug.WriteLine($"SalesRepID: {Row.SalesRepID}");
            System.Diagnostics.Debug.WriteLine($"SalesAmount: {Row.SalesAmount}");
            System.Diagnostics.Debug.WriteLine($"Discount: {Row.Discount}");
            System.Diagnostics.Debug.WriteLine($"NetAmount: {Row.NetAmount}");
        }

        // Convert TransactionID (keep as string)
        string transactionId = "";
        if (!Row.TransactionID_IsNull)
        {
            transactionId = Row.TransactionID.ToString().Trim();
        }
        int convTransactionID = int.TryParse(transactionId, out var tid) ? tid : 0;

        // Convert TransactionDate
        DateTime transactionDate = new DateTime(1900, 1, 1);
        if (!Row.TransactionDate_IsNull)
        {
            string val = Row.TransactionDate.ToString().Trim();
            if (!string.IsNullOrEmpty(val))
            {
                DateTime.TryParse(val, out transactionDate);
                if (rowCount <= 5) System.Diagnostics.Debug.WriteLine($"Parsed TransactionDate: {transactionDate}");
            }
        }
        Row.convTransactionDate = transactionDate;

        // Convert ProductID (convert to int)
        int productId = 0;
        if (!Row.ProductID_IsNull)
        {
            string val = Row.ProductID.ToString().Trim();
            if (!string.IsNullOrEmpty(val))
            {
                int.TryParse(val, out productId);
            }
        }
        // Row.convProductID = productId; // convProductID not defined on Input0Buffer. Add an output column in the SSIS designer if you need this stored.

        // Convert CustomerID (store in convCustomerID as int)
        int customerId = 0;
        if (!Row.CustomerID_IsNull)
        {
            string val = Row.CustomerID.ToString().Trim();
            if (!string.IsNullOrEmpty(val))
            {
                int.TryParse(val, out customerId);
            }
        }
        // Row.convCustomerID = customerId; // convCustomerID not defined on Input0Buffer. Add an output column in the SSIS designer if you need this stored.

        // Convert SalesRepID (convert to int)
        int salesRepId = 0;
        if (!Row.SalesRepID_IsNull)
        {
            string val = Row.SalesRepID.ToString().Trim();
            if (!string.IsNullOrEmpty(val))
            {
                int.TryParse(val, out salesRepId);
            }
        }
        // Row.convSalesRepID = salesRepId; // convSalesRepID not defined on Input0Buffer. Add an output column in the SSIS designer if you need this stored.

        // Convert SalesAmount
        decimal salesAmount = 0;
        if (!Row.SalesAmount_IsNull)
        {
            string val = Row.SalesAmount.ToString().Trim();
            if (!string.IsNullOrEmpty(val))
            {
                decimal.TryParse(val, out salesAmount);
                salesAmount = Math.Round(salesAmount, 2);
                if (rowCount <= 5) System.Diagnostics.Debug.WriteLine($"Parsed SalesAmount: {salesAmount}");
            }
        }
        Row.convSalesAmount = salesAmount;

        // Convert Discount
        decimal discount = 0;
        if (!Row.Discount_IsNull)
        {
            string val = Row.Discount.ToString().Trim();
            if (!string.IsNullOrEmpty(val))
            {
                decimal.TryParse(val, out discount);
                discount = Math.Round(discount, 2);
                if (rowCount <= 5) System.Diagnostics.Debug.WriteLine($"Parsed Discount: {discount}");
            }
        }
        Row.convDiscount = discount;

        // Convert NetAmount
        decimal netAmount = 0;
        if (!Row.NetAmount_IsNull)
        {
            string val = Row.NetAmount.ToString().Trim();
            if (!string.IsNullOrEmpty(val))
            {
                decimal.TryParse(val, out netAmount);
                netAmount = Math.Round(netAmount, 2);
                if (rowCount <= 5) System.Diagnostics.Debug.WriteLine($"Parsed NetAmount: {netAmount}");
            }
        }
        Row.convNetAmount = netAmount;


        if (rowCount <= 5) System.Diagnostics.Debug.WriteLine("---");
    }
}]]></arrayElement>
