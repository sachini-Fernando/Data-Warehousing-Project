      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{AA8C83B3-30A2-4955-9DAA-3EBBD0AC0E60}"
          SQLTask:SqlStatementSource="UPDATE Landing_Transactions&#xA;SET Processed = 1&#xA;WHERE Processed = 0 OR Processed IS NULL" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
